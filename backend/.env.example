# ============================================================
# BOM System – Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de Dados ---
# Local (SQLite):
DATABASE_URL=sqlite:///./bom_system.db
# Produção (PostgreSQL no Railway - cole a URL fornecida pelo Railway):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# --- Segurança JWT ---
# Gere uma chave aleatória segura para produção:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-em-producao-use-uma-chave-aleatoria-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS (origens permitidas, separadas por vírgula) ---
# Local:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Produção (adicione sua URL do GitHub Pages):
# ALLOWED_ORIGINS=http://localhost:5173,https://SEU-USUARIO.github.io,https://seu-dominio.com.br
