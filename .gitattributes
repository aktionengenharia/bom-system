# Normalizar line endings: checkout Windows=CRLF, commit=LF
* text=auto

# Arquivos que DEVEM ter LF (Linux/CI)
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
Procfile    text eol=lf

# Arquivos que DEVEM ter CRLF (Windows)
*.bat       text eol=crlf

# Binarios - sem conversao
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.xlsm      binary
*.xlsx      binary
*.xmind     binary
*.pdf       binary
*.docx      binary