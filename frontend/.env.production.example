# ============================================================
# Frontend – Produção (GitHub Pages + Railway)
# Copie para .env.production e preencha com seus valores
# ============================================================

# URL do backend no Railway (sem barra no final)
# Ex: https://bom-api-production.up.railway.app
VITE_API_URL=https://SEU-APP.up.railway.app

# Base path para GitHub Pages SEM domínio custom:
# Ex: se o repo é github.com/joao/bom-system → use /bom-system/
# Se tiver domínio custom (CNAME) → deixe como /
VITE_BASE_PATH=/
